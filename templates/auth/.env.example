# =============================================================================
# WorkOS Configuration
# Get these from https://dashboard.workos.com
# =============================================================================

# Your WorkOS Client ID (starts with "client_")
WORKOS_CLIENT_ID=client_xxx

# Your WorkOS API Key (starts with "sk_")
WORKOS_API_KEY=sk_xxx

# The URL WorkOS redirects to after login
# Must match the redirect URI configured in WorkOS Dashboard
WORKOS_REDIRECT_URI=http://localhost:3000/auth/callback

# Secret key for encrypting session cookies (minimum 32 characters)
# Generate with: openssl rand -base64 32
WORKOS_COOKIE_PASSWORD=your-cookie-password-must-be-at-least-32-characters

# =============================================================================
# Convex Configuration
# This is set automatically when you run `npx convex dev`
# =============================================================================

# VITE_CONVEX_URL=https://your-deployment.convex.cloud

# =============================================================================
# API Key for M2M / HTTP Action Access (optional)
# Set this as a Convex environment variable:
#   npx convex env set API_KEY "your-generated-key"
# Generate with: openssl rand -base64 32
# =============================================================================
